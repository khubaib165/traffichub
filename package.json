    "stripe": "^14.19.0",
    "@stripe/react-stripe-js": "^2.7.0",
    "@stripe/stripe-js": "^3.0.0",
    "recharts": "^2.10.3",
    "lucide-react": "^0.372.0",
    "zustand": "^4.4.7",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
